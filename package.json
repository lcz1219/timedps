{
  "name": "timedps",
  "displayName": "TimedPS 用量统计",
  "description": "通过本地代理统计第三方 AI 接口的 Token 用量和预估费用",
  "version": "0.0.6",
  "icon": "images/icon.png",
  "license": "MIT",
  "publisher": "lcz",
  "repository": {
    "type": "git",
    "url": "https://github.com/lcz1219/timedps"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-usage-tracker.showUsage",
        "title": "AI 用量：查看详情"
      },
      {
        "command": "ai-usage-tracker.resetUsage",
        "title": "AI 用量：重置统计",
        "icon": "$(trash)"
      },
      {
        "command": "ai-usage-tracker.refreshBalance",
        "title": "AI 用量：刷新官方余额"
      },
      {
        "command": "ai-usage-tracker.setApiKey",
        "title": "AI 用量：手动设置 API Key"
      },
      {
        "command": "ai-usage-tracker.refreshTree",
        "title": "AI 用量：刷新历史记录",
        "icon": "$(refresh)"
      },
      {
        "command": "ai-usage-tracker.showGatewayLog",
        "title": "AI 用量：查看网关日志"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-usage-tracker-sidebar",
          "title": "AI 用量",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "ai-usage-tracker-sidebar": [
        {
          "id": "ai-usage-tracker-tree",
          "name": "用量历史"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "ai-usage-tracker.refreshTree",
          "when": "view == ai-usage-tracker-tree",
          "group": "navigation"
        },
        {
          "command": "ai-usage-tracker.resetUsage",
          "when": "view == ai-usage-tracker-tree",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "AI 用量统计",
      "properties": {
        "aiUsageTracker.targetApiUrl": {
          "type": "string",
          "default": "https://api.deepseek.com",
          "description": "实际转发到的目标 API 基础地址，例如 https://api.deepseek.com"
        },
        "aiUsageTracker.proxyPort": {
          "type": "number",
          "default": 31234,
          "description": "本地代理服务监听的端口"
        },
        "aiUsageTracker.currencySymbol": {
          "type": "string",
          "default": "¥",
          "description": "界面显示使用的货币符号，例如 ¥、$"
        },
        "aiUsageTracker.inputPricePerMillion": {
          "type": "number",
          "default": 1,
          "description": "每 100 万输入 Token 的价格，默认 1.0（DeepSeek V3 未命中缓存）"
        },
        "aiUsageTracker.outputPricePerMillion": {
          "type": "number",
          "default": 2,
          "description": "每 100 万输出 Token 的价格，默认 2.0（DeepSeek V3）"
        },
        "aiUsageTracker.cacheHitPricePerMillion": {
          "type": "number",
          "default": 0.1,
          "description": "每 100 万缓存命中输入 Token 的价格，默认 0.1（DeepSeek V3 缓存命中）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "package": "source ~/.nvm/nvm.sh && nvm use 20 && npx @vscode/vsce package --no-dependencies --allow-star-activation"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.1.3"
  }
}
